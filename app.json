{
  "expo": {
    "name": "TransApp_upd",
    "slug": "TransApp_upd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/truck.png",
    "scheme": "transappupd",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.reactjs.native.example.Transappru",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Приложение использует вашу геолокацию для отображения на карте",
        "NSLocationAlwaysUsageDescription": "Приложение использует вашу геолокацию для отображения на карте"
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "org.reactjs.native.example.Transappru",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "./plugins/withPodfileModifications.js",
      "./plugins/withAPSEnvironment.js",
      "./plugins/withYandexMaps.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/truck.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
