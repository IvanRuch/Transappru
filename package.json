{
  "name": "transapp_upd",
  "main": "expo-router/entry",
  "version": "2.0.17",
  "scripts": {
    "test": "NODE_ENV=test jest --no-watchman",
    "test:watch": "NODE_ENV=test jest --watch --no-watchman",
    "test:coverage": "NODE_ENV=test jest --coverage --no-watchman",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:clear": "adb shell pm clear com.transappru && npm run android",
    "android:fresh": "adb uninstall com.transappru; npm run android",
    "android:device": "npm run setup:device && expo run:android --device",
    "android:device:specific": "npm run setup:device:specific && expo run:android --device 28J9K24319016011",
    "setup:device": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:8097 tcp:8097",
    "setup:device:specific": "adb -s 28J9K24319016011 reverse tcp:8081 tcp:8081 && adb -s 28J9K24319016011 reverse tcp:8097 tcp:8097",
    "device:list": "adb devices",
    "device:logs": "adb logcat -s ReactNativeJS:I ReactNative:I",
    "device:clear": "adb shell pm clear com.transappru",
    "ios": "expo run:ios",
    "ios:17": "expo run:ios --device 'iPhone 17 Pro Max'",
    "ios:clear": "xcrun simctl uninstall booted org.reactjs.native.example.Transappru && npm run ios",
    "ios:fresh": "xcrun simctl erase booted && npm run ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "push:colleague": "bash scripts/push-to-colleague.sh",
    "git:sync": "git fetch upstream && git merge upstream/functional-ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/app": "^23.5.0",
    "@react-native-firebase/messaging": "^23.5.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/stack": "^7.6.2",
    "axios": "^1.13.1",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.10",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-device-info": "^14.1.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-yamap-plus": "^6.2.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@expo/config-plugins": "^54.0.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "babel-jest": "^30.3.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@firebase/auth": {
      "@react-native-async-storage/async-storage": "$@react-native-async-storage/async-storage"
    }
  },
  "private": true
}
