# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# JetBrains IDE — machine-specific module config (rewrites on every
# project open with different absolute paths, version markers, JDK
# locations). Shared .idea/*.xml configs stay tracked.
.idea/*.iml

# macOS
.DS_Store
*.pem
# Exception: VPN server CA cert is public (distributed to all
# clients) and must travel with the source for the StrongSwan
# sidecar build (ADR-015).
!infra/strongswan/ca.pem

# local env files
.env
.env*.local

# Generated FCM service worker (rendered from
# public/firebase-messaging-sw.template.js by `npm run gen:sw` locally,
# or by sed in nginx/Dockerfile.prod during production builds). Never
# commit — config drifts between dev/prod and there's no value in versioning it.
public/firebase-messaging-sw.js

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Firebase configs (production secrets)
google-services.json
GoogleService-Info.plist
old-project

# Local-only secrets (Yandex Cloud SA JSON keys, ad-hoc credentials, etc.)
# Files here MUST never reach the remote — copy values into GitHub Secrets and
# (ideally) delete locally afterwards.
.secrets/

# Claude Code local settings (machine-specific paths)
.claude/settings.local.json

# Claude Code session state (auto-written by PreCompact hook, per-session)
.claude/session-state.md

# Playwright MCP (test artifacts)
.playwright-mcp/

# Test screenshots (from Playwright browser testing)
*.screenshot.png
pass-*.png
add-auto-*.png
current-auto-list.png
improved-auto-list.png
inn-screen-web.png

# Symlinks to external repos
backend_reference
/Transappru/
/transappweb/
