# TransApp Web + Payment — Production Environment
# These values must be set as GitHub Secrets for the deploy-web.yml workflow.

# ── Yandex Cloud ──────────────────────────────────────
YC_SA_JSON_CREDENTIALS=      # Service account JSON key (entire file contents)
YC_FOLDER_ID=                # Yandex Cloud folder ID
YC_REGISTRY_ID=              # Container Registry ID (cr.yandex/...)
YC_SERVICE_ACCOUNT_ID=       # SA ID assigned to the VM
YC_SUBNET_ID=                # Subnet in ru-central1-d
YC_VM_NAME=transapp-web      # VM instance name
YC_VM_SSH=                   # Public SSH key for VM access
YC_VM_USERNAME=deploy        # Username on the VM
YC_VM_PUBLIC_IP=             # Static public IP address

# ── SSL ───────────────────────────────────────────────
YC_CERT_ID=                  # Yandex Certificate Manager certificate ID

# ── Payment Service DB (PostgreSQL) ──────────────────
PG_USER=postgres
PG_PASSWORD=                 # Strong password for production
PG_NAME=payment_db

# ── Kazna Payment Gateway ────────────────────────────
KAZNA_API_URL=https://pay.oplatagosuslug.ru/api/kazna/2.2
KAZNA_SECRET_KEY=            # Production secret key
KAZNA_TOKEN=                 # Production token
