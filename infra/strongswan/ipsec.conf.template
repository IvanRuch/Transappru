config setup
    charondebug="ike 2, knl 2, cfg 2"

# Split-tunnel client config — only Telegram API subnets are routed
# through the IPsec tunnel; all other outbound traffic continues to
# use the host default route.
#
# Keep `rightsubnet` in sync with the published Telegram IP ranges
# (https://core.telegram.org/resources/cidr.txt — listed below).
# Adding routes here without keeping the upstream firewall in sync
# can break BotAPI / DCs.
conn telegram-vpn
    keyexchange=ikev2
    ike=aes256-sha256-modp2048!
    esp=aes256-sha256!

    left=%defaultroute
    leftsourceip=%config
    leftauth=eap-mschapv2
    eap_identity=__EAP_USERNAME__

    right=31.44.2.124
    rightauth=pubkey
    rightid=%any
    # Telegram API CIDRs — full list from
    # https://core.telegram.org/resources/cidr.txt (IPv4 only;
    # IPv6 is disabled in the vpn container by entrypoint.sh, so
    # `aiohappyeyeballs` resolves only A records and never tries
    # AAAA — see ADR-015 troubleshooting). Original two-subnet list
    # (149.154.160.0/20 + 91.108.4.0/22) inherited from the
    # `krasilnikov-bitrix-teleg-bot` config was incomplete: TG DNS
    # rotates `api.telegram.org` across DC1–DC5 and the long-poll
    # `getUpdates` cycle hit a non-routed IP roughly every 4-th
    # iteration, leaving the bot in a permanent timeout loop. The
    # full list below covers all DCs.
    rightsubnet=91.105.192.0/23,91.108.4.0/22,91.108.8.0/22,91.108.12.0/22,91.108.16.0/22,91.108.20.0/22,91.108.56.0/22,95.161.64.0/20,149.154.160.0/20,185.76.151.0/24

    auto=start
