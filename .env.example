# Local-development environment variables for Expo Web.
#
# Copy this file to `.env` (gitignored) and fill in real values to test
# web push notifications locally. Without these vars `isFirebaseWebConfigured()`
# returns false and the push pipeline is a no-op (banner hidden, hook exits
# early — same behaviour as before web push was wired up).
#
# Production deploys read the same names from GitHub Secrets through
# `nginx/Dockerfile.prod` build args — see Writerside/topics/dev-push-notifications.md.
#
# IMPORTANT: only variables prefixed with EXPO_PUBLIC_ are exposed to the
# client bundle by Metro. Do NOT put real secrets here — Firebase web
# `apiKey` and VAPID public key ARE public values by design (visible in
# any web SPA bundle) and protected by Firebase Security Rules / billing
# limits, not by secrecy.

# === REQUIRED for web push to activate (3 values) ===

# Firebase Console → Project Settings → Your apps → Web app → SDK setup → apiKey
EXPO_PUBLIC_FIREBASE_WEB_API_KEY=

# Same Web app → appId (looks like "1:1234567890:web:abcdef")
EXPO_PUBLIC_FIREBASE_WEB_APP_ID=

# Firebase Console → Cloud Messaging → Web Push certificates → Generate key pair
# Copy the PUBLIC half only (looks like "BNs...AAw", ~88 chars).
EXPO_PUBLIC_FIREBASE_WEB_VAPID_KEY=

# === DERIVABLE from google-services.json (3 values, but kept as env for parity) ===

# google-services.json:project_info.project_id
EXPO_PUBLIC_FIREBASE_WEB_PROJECT_ID=

# google-services.json:project_info.project_number
EXPO_PUBLIC_FIREBASE_WEB_MESSAGING_SENDER_ID=

# google-services.json:project_info.storage_bucket
EXPO_PUBLIC_FIREBASE_WEB_STORAGE_BUCKET=
